# MQTT broker WebSocket URL (as seen from the user's browser)
# For local dev: ws://localhost:9001
# For LAN access from other devices: ws://<HOST_IP>:9001
NEXT_PUBLIC_MQTT_URL=ws://localhost:9001

# Your GivEnergy inverter serial number (found on the inverter or in GivTCP config)
NEXT_PUBLIC_INVERTER_SERIAL=YOUR_SERIAL_HERE

# Octopus Energy API (server-only — do NOT prefix with NEXT_PUBLIC_)
OCTOPUS_API_KEY=sk_live_xxxxxxxxxxxx
OCTOPUS_ACCOUNT=A-XXXXXXXX
