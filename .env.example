# GivEnergy Inverter
INVERTER_SERIAL=your_inverter_serial_here

# MQTT WebSocket URL (as seen from the user's browser)
# Use the host IP if accessing from other devices on LAN
# e.g., ws://192.168.1.100:9001
NEXT_PUBLIC_MQTT_URL=ws://localhost:9001

# Octopus Energy API (optional - for Intelligent Go features)
OCTOPUS_API_KEY=your_octopus_api_key_here
OCTOPUS_ACCOUNT=your_account_number_here
